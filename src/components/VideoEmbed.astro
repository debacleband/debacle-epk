---
interface Props {
  title: string;
  url: string;
  desc?: string;
}

const { title, url, desc } = Astro.props;

type EmbedInfo = { url: string; portrait: boolean } | null;

function toEmbedInfo(raw: string): EmbedInfo {
  // YouTube: watch?v=ID or youtu.be/ID or shorts/ID
  let m = raw.match(
    /(?:youtube\.com\/(?:watch\?v=|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/,
  );
  if (m)
    return {
      url: `https://www.youtube.com/embed/${m[1]}?rel=0`,
      portrait: false,
    };

  // Instagram Reel or post: /reel/ID/ or /p/ID/
  m = raw.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/);
  if (m)
    return {
      url: `https://www.instagram.com/reel/${m[1]}/embed/`,
      portrait: true,
    };

  return null;
}

const embed = toEmbedInfo(url);
---

{
  embed ? (
    <div class="flex flex-col gap-2 rounded-xl bg-zinc-900 p-4">
      <h3 class="text-base font-semibold">{title}</h3>
      {desc && <p class="text-sm text-zinc-400">{desc}</p>}
      <div
        class={`relative overflow-hidden rounded-xl bg-zinc-900 ${embed.portrait ? "aspect-[9/16] max-w-xs w-full self-center" : "aspect-video"}`}>
        <iframe
          src={embed.url}
          title={title}
          width="100%"
          height="100%"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
          class="absolute inset-0 h-full w-full"
        />
      </div>
      <p class="music-print-link hidden text-xs text-zinc-500">
        Video:{" "}
        <a href={url} target="_blank" rel="noopener noreferrer">
          {url}
        </a>
      </p>
    </div>
  ) : (
    <p class="text-sm text-zinc-500">Unsupported video URL: {url}</p>
  )
}
