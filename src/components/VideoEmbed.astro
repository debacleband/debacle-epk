---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

function toEmbedUrl(raw: string): string | null {
  // YouTube: watch?v=ID or youtu.be/ID or shorts/ID
  let m = raw.match(/(?:youtube\.com\/(?:watch\?v=|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  if (m) return `https://www.youtube.com/embed/${m[1]}?rel=0`;

  // Vimeo: vimeo.com/ID or player.vimeo.com/video/ID
  m = raw.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (m) return `https://player.vimeo.com/video/${m[1]}?dnt=1`;

  return null;
}

const embedUrl = toEmbedUrl(url);
---

{embedUrl ? (
  <div class="flex flex-col gap-2">
    <h3 class="text-base font-semibold">{title}</h3>
    <div class="relative aspect-video overflow-hidden rounded-xl bg-zinc-900">
      <iframe
        src={embedUrl}
        title={title}
        width="100%"
        height="100%"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
        class="absolute inset-0 h-full w-full"
      />
    </div>
    <!-- Print fallback -->
    <p class="music-print-link hidden text-xs text-zinc-500">
      Video: <a href={url} target="_blank" rel="noopener noreferrer">{url}</a>
    </p>
  </div>
) : (
  <p class="text-sm text-zinc-500">Unsupported video URL: {url}</p>
)}
