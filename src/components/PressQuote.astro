---
interface Props {
  quote: string;
  source: string;
}

const { quote, source } = Astro.props;
---

<figure class="rounded-xl border border-zinc-800 bg-zinc-900 p-6">
  <blockquote class="text-lg italic leading-relaxed text-zinc-200 before:content-['\201C'] after:content-['\201D']">
    {quote}
  </blockquote>
  <figcaption class="mt-3 text-sm font-medium text-zinc-400">
    — {source}
  </figcaption>
</figure>
