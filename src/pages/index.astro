---
import Layout from "../layouts/Layout.astro";
import Carousel from "../components/Carousel.astro";
import MusicEmbed from "../components/MusicEmbed.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import PressQuote from "../components/PressQuote.astro";
import { getEpk, urlFor, portableTextToHtml } from "../lib/sanity";

const epk = await getEpk().catch(() => null);

const data = epk ?? {
  bandName: "Your Band Name",
  tagline: "Your tagline goes here",
  genres: ["Genre"],
  heroImage: null,
  biography: null,
  onlinePresence: null,
  tracks: [],
  photos: [],
  videos: [],
  pressQuotes: [],
  contact: null,
};

const heroUrl = data.heroImage
  ? urlFor(data.heroImage).width(1600).height(700).auto("format").url()
  : null;

const bioHtml = data.biography ? portableTextToHtml(data.biography) : null;
const onlineHtml = data.onlinePresence
  ? portableTextToHtml(data.onlinePresence)
  : null;
---

<Layout
  title={`${data.bandName} — Electronic Press Kit`}
  description={data.tagline}
  ogImage={heroUrl ?? undefined}
>
  <!-- Hero -->
  <header
    class="relative flex min-h-[60vh] items-end bg-zinc-900 px-6 pb-12 md:px-12"
  >
    {
      heroUrl && (
        <img
          src={heroUrl}
          alt={data.bandName}
          class="absolute inset-0 h-full w-full object-cover opacity-40"
          fetchpriority="high"
        />
      )
    }
    <div class="relative z-10 max-w-4xl">
      <h1 class="text-5xl font-black tracking-tight md:text-7xl mt-3">
        {data.bandName}
      </h1>
      {
        data.genres && data.genres.length > 0 && (
          <div class="mb-3 flex flex-wrap gap-2 mt-3">
            {data.genres.map((g) => (
              <span class="rounded-full border border-zinc-400 px-3 py-1 text-xs font-medium uppercase tracking-widest text-zinc-400">
                {g}
              </span>
            ))}
          </div>
        )
      }
      {
        data.tagline && (
          <p class="mt-3 text-lg text-zinc-300 md:text-lg">{data.tagline}</p>
        )
      }
    </div>
  </header>

  <main class="mx-auto max-w-4xl space-y-20 px-6 py-16 md:px-12">
    <!-- Biography -->
    {
      bioHtml && (
        <section aria-labelledby="bio-heading">
          <h2 id="bio-heading" class="section-heading">
            Bio
          </h2>
          <div
            class="prose prose-invert prose-zinc max-w-none text-zinc-300 [&_p]:leading-relaxed [&_h2]:text-zinc-100 [&_h3]:text-zinc-100"
            set:html={bioHtml}
          />
        </section>
      )
    }

    <!-- Music -->
    {
      data.tracks && data.tracks.length > 0 && (
        <section aria-labelledby="music-heading">
          <h2 id="music-heading" class="section-heading">
            Musique
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {data.tracks.map((track) => (
              <MusicEmbed track={track} />
            ))}
          </div>
        </section>
      )
    }

    <!-- Online Presence -->

    {
      onlineHtml && (
        <section aria-labelledby="online-heading" class="h-full">
          <h2 id="online-heading" class="section-heading">
            En ligne
          </h2>
          <div class="flex flex-row justify-end gap-3 h-full">
            <div>
              <h2
                  id="socials-heading"
                  class="uppercase text- lg font-bold tracking-tight text-zinc-300"
                >
                  Streaming
                </h2>
              {data.contact && (
                <div class="mt-3 mb-3 flex flex-row gap-3">
                  {data.contact.spotify && (
                    <a
                      href={data.contact.spotify}
                      class="social-link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Spotify
                    </a>
                  )}
                  {data.contact.deezer && (
                    <a
                      href={data.contact.deezer}
                      class="social-link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Deezer
                    </a>
                  )}
                  {data.contact.appleMusic && (
                    <a
                      href={data.contact.appleMusic}
                      class="social-link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Apple Music
                    </a>
                  )}
                </div>
              )}
              <div
                class="prose prose-invert prose-zinc max-w-none text-zinc-300 [&_p]:leading-relaxed [&_h2]:text-zinc-100 [&_h3]:text-zinc-100"
                set:html={onlineHtml}
              />
            </div>
            {data.contact && (
              <div class="flex flex-col justify-end">
                <h2
                  id="socials-heading"
                  class="uppercase text- lg font-bold tracking-tight text-zinc-300"
                >
                  Réseaux Sociaux
                </h2>

                <div class="mt-3 flex flex-wrap">
                  <div class="mb-3 flex flex-row gap-3">
                    {data.contact.instagram && (
                      <a
                        href={data.contact.instagram}
                        class="social-link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Instagram
                      </a>
                    )}
                    {data.contact.tiktok && (
                      <a
                        href={data.contact.tiktok}
                        class="social-link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        TikTok
                      </a>
                    )}
                  </div>
                  <img
                    src="/instagram-screen.png"
                    alt="Instagram screen"
                    class="flex-none w-120 rounded-t-xl"
                  />
                  <img
                    src="/instagram-screen2.png"
                    alt="Instagram screen"
                    class="flex-none w-120 rounded-b-xl"
                  />
                </div>
              </div>
            )}
          </div>
        </section>
      )
    }

    <!-- Visuals -->
    {
      data.photos && data.photos.length > 0 && (
        <section aria-labelledby="photos-heading">
          <h2 id="photos-heading" class="section-heading">
            Photos
          </h2>
          <Carousel photos={data.photos} />
        </section>
      )
    }

    <!-- Videos -->
    {
      data.videos && data.videos.length > 0 && (
        <section aria-labelledby="videos-heading">
          <h2 id="videos-heading" class="section-heading">
            Vidéos
          </h2>
          <div class="grid gap-8 sm:grid-cols-2">
            {data.videos.map((video) => (
              <VideoEmbed title={video.title} url={video.url} />
            ))}
          </div>
        </section>
      )
    }

    <!-- Press -->
    {
      data.pressQuotes && data.pressQuotes.length > 0 && (
        <section aria-labelledby="press-heading">
          <h2 id="press-heading" class="section-heading">
            Presse
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {data.pressQuotes.map((pq) => (
              <PressQuote quote={pq.quote} source={pq.source} />
            ))}
          </div>
        </section>
      )
    }

    <!-- Contact -->
    {
      data.contact && (
        <section aria-labelledby="contact-heading">
          <h2 id="contact-heading" class="section-heading">
            Contact
          </h2>
          <div class="grid gap-6 sm:grid-cols-2">
            {data.contact.bookingEmail && (
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
                  Booking
                </p>
                <a
                  href={`mailto:${data.contact.bookingEmail}`}
                  class="mt-1 text-zinc-200 hover:text-white transition"
                >
                  {data.contact.bookingEmail}
                </a>
              </div>
            )}
            {data.contact.pressEmail && (
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
                  Presse
                </p>
                <a
                  href={`mailto:${data.contact.pressEmail}`}
                  class="mt-1 text-zinc-200 hover:text-white transition"
                >
                  {data.contact.pressEmail}
                </a>
              </div>
            )}
            {data.contact.website && (
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
                  Site web
                </p>
                <a
                  href={data.contact.website}
                  class="mt-1 text-zinc-200 hover:text-white transition"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {data.contact.website}
                </a>
              </div>
            )}
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            {data.contact.instagram && (
              <a
                href={data.contact.instagram}
                class="social-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                Instagram
              </a>
            )}
            {data.contact.tiktok && (
              <a
                href={data.contact.tiktok}
                class="social-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                TikTok
              </a>
            )}
            {data.contact.spotify && (
              <a
                href={data.contact.spotify}
                class="social-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                Spotify
              </a>
            )}
            {data.contact.deezer && (
              <a
                href={data.contact.deezer}
                class="social-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                Deezer
              </a>
            )}
            {data.contact.appleMusic && (
              <a
                href={data.contact.appleMusic}
                class="social-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                Apple Music
              </a>
            )}
          </div>
        </section>
      )
    }
  </main>

  <footer
    class="border-t border-zinc-800 px-6 py-8 text-center text-xs text-zinc-600 md:px-12"
  >
    {data.bandName} — Electronic Press Kit
  </footer>
</Layout>

<style>
  @reference "../styles/global.css";

  .section-heading {
    @apply mb-6 text-2xl font-bold tracking-tight text-zinc-100 md:text-3xl;
    @apply border-b border-zinc-800 pb-3;
  }

  .social-link {
    @apply rounded-full border-2 border-zinc-400 px-4 py-2 text-sm font-medium text-zinc-400 transition hover:border-white hover:text-white;
  }
</style>
