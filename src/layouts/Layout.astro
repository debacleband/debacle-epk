---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = '', ogImage } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="bg-zinc-950 text-zinc-100 font-sans antialiased">
    <slot />

    <button
      id="print-btn"
      onclick="window.print()"
      class="fixed bottom-6 right-6 z-50 flex items-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-zinc-900 shadow-lg transition hover:bg-zinc-200 print:hidden"
      aria-label="Export as PDF"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 6 2 18 2 18 9"></polyline>
        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
        <rect x="6" y="14" width="12" height="8"></rect>
      </svg>
      Export PDF
    </button>
  </body>
</html>

<style is:global>
  /* ── Print styles ─────────────────────────────────────── */
  @media print {
    @page {
      margin: 20mm 15mm;
      size: A4;
    }

    body {
      background: #fff !important;
      color: #111 !important;
      font-size: 11pt;
    }

    /* Hide interactive elements */
    #print-btn,
    .carousel-nav,
    .carousel-dots,
    iframe { display: none !important; }

    /* Expand carousel into a grid */
    .carousel-track {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      gap: 8px !important;
      overflow: visible !important;
      transform: none !important;
    }

    .carousel-slide {
      display: block !important;
      flex: none !important;
      width: 100% !important;
      break-inside: avoid;
    }

    /* Show print-only Spotify/Deezer links instead of iframes */
    .music-print-link { display: block !important; }

    /* Page break hints */
    section { break-inside: avoid; }
    h2 { break-after: avoid; }

    /* Preserve colours for press kit feel */
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    a { color: inherit; text-decoration: none; }
  }
</style>
